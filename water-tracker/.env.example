VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — only needed for real background push notifications.
# Generate with: npx web-push generate-vapid-keys
# (public key goes here in the frontend; keep the private key only in
# Supabase's function secrets, never in this file or the client bundle)
VITE_VAPID_PUBLIC_KEY=
