VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — only needed for real background push notifications.
# Create a free app at onesignal.com and paste its App ID here.
# (The REST API key, used server-side by scripts/send-reminders.mjs, is
# never put in this file — it's a GitHub Actions secret instead. See the
# README's "Real push notifications" section.)
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
